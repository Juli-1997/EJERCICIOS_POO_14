package com.mypoo2.ejercicio_14;


public class calculos_14 {

    public static double calcularCuadrado(int num) {
        return (int) Math.pow(num, 2);
    }

    public static double calcularCubo(int num) {
        return Math.pow(num, 3);
    }
}
